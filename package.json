{
  "name": "acorn-tools",
  "version": "1.0.0",
  "description": "Acorn Tools — Free private PDF & image tools. Compress, convert, resize, crop, merge — 100% offline.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cybermax-008/Acorn-tools.git"
  },
  "homepage": "https://www.acorntools.net",
  "bugs": {
    "url": "https://github.com/cybermax-008/Acorn-tools/issues"
  },
  "keywords": [
    "pdf",
    "image",
    "compress",
    "resize",
    "convert",
    "crop",
    "privacy",
    "offline",
    "pwa",
    "wasm"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "cap:init": "cap init AcornTools com.acorntools.app --web-dir dist",
    "cap:add:ios": "cap add ios",
    "cap:add:android": "cap add android",
    "cap:sync": "npm run build && cap sync",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.5.207",
    "pica": "^9.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.13.1",
    "wasm-vips": "^0.0.11"
  },
  "devDependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/cli": "^6.2.0",
    "@capacitor/core": "^6.2.0",
    "@capacitor/filesystem": "^6.0.2",
    "@capacitor/ios": "^6.2.0",
    "@capacitor/share": "^6.0.3",
    "@capacitor/splash-screen": "^6.0.2",
    "@capacitor/status-bar": "^6.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.1"
  }
}
